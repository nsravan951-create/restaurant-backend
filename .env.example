PORT=5000
NODE_ENV=development

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/qr_restaurant
DATABASE_SSL=false

# Comma-separated allowed browser origins (include your frontend URL)
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5500

# Public URL used inside generated QR codes
FRONTEND_PUBLIC_URL=https://restaurantts.netlify.app

JWT_SECRET=change-this-to-a-long-random-secret
SUPER_ADMIN_SETUP_KEY=change-this-setup-key

# Razorpay (test or live keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx

# Optional UPI webhook verification
UPI_WEBHOOK_SECRET=

# Table session timeout in minutes
TABLE_SESSION_TIMEOUT_MINUTES=20
